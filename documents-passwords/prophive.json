      "afterResponseScript": "const regex = /\\|(.*)$/;\nconst authHeader = response.headers.find(h => h.name === 'Authorization');\n\nif (authHeader) {\n  const token = authHeader.value.replace('Bearer ', '');\n  insomnia.environment.set('adminToken', token);\n  insomnia.environment.set('token', token);\n  console.log('Admin token stored successfully');\n} else if (response.body && response.body.token) {\n  insomnia.environment.set('adminToken', response.body.token);\n  insomnia.environment.set('token', response.body.token);\n  console.log('Admin token stored successfully');\n}"
